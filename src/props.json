{
  "$preview": {
    "width": 1320,
    "height": 880
  },
  "defaultMeasure": {
    "editor": "enum",
    "default": "rate",
    "options": [
      "rate",
      "share",
      "txrate"
    ],
    "tsType": "\"rate\"|\"share\""
  },
  "flowHeight": {
    "editor": "int",
    "default": 440,
    "min": 320,
    "max": 1000,
    "step": 20,
    "tsType": "number"
  },
  "palette": {
    "editor": "enum",
    "default": "editorial",
    "options": [
      "editorial",
      "spectrum",
      "muted"
    ],
    "tsType": "string"
  },
  "ribbonOpacity": {
    "editor": "float",
    "default": 0.2,
    "min": 0,
    "max": 0.45,
    "step": 0.05,
    "tsType": "number"
  },
  "hideNoise": {
    "editor": "boolean",
    "default": false,
    "tsType": "boolean"
  }
}